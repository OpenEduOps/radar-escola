{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Radar Escola",
  "version": "0.0.1",
  "identifier": "br.org.openeduops.radarescola",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Radar Escola",
        "width": 1000,
        "height": 580,
        "maximized": true,
        "minWidth": 860,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Education",
    "shortDescription": "Aplicativo desktop local para escolas.",
    "longDescription": "Scaffold tecnico minimo do futuro aplicativo desktop Radar Escola."
  }
}
